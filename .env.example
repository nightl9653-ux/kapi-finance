# 复制为 `.env.local` 后填入真实值（勿提交 Git）。
#
# Supabase：仅用云端项目，到 Dashboard → Project Settings → API 复制下面两项
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# 可选：AI 每日限额（Free / Plus 分档；未设置则用代码内默认值）
# FREE_SCAN_DAILY_LIMIT=5
# PLUS_SCAN_DAILY_LIMIT=20
# FREE_VOICE_DAILY_LIMIT=3
# PLUS_VOICE_DAILY_LIMIT=12
# FREE_ASSISTANT_DAILY_LIMIT=20
# PLUS_ASSISTANT_DAILY_LIMIT=80
# FREE_DREAM_VISUAL_DAILY_LIMIT=3
# PLUS_DREAM_VISUAL_DAILY_LIMIT=10
# FREE_DREAM_VISUAL_HQ_DAILY_LIMIT=0
# PLUS_DREAM_VISUAL_HQ_DAILY_LIMIT=3
# FREE_DREAM_STORY_DAILY_LIMIT=5
# PLUS_DREAM_STORY_DAILY_LIMIT=15
# FREE_DREAM_LOCALIZED_MEDIA_DAILY_LIMIT=5
# PLUS_DREAM_LOCALIZED_MEDIA_DAILY_LIMIT=15
