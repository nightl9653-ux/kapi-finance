# 复制为 `.env.local` 后填入真实值（勿提交 Git）。
#
# Supabase：仅用云端项目，到 Dashboard → Project Settings → API 复制下面两项
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# 可选：AI 每日限额（Free / Plus 分档；未设置则用代码内默认值）
# 扫单次数写在 ai_usage.screenshot_count；勿使用已废弃的 SCAN_RECEIPT_DAILY_LIMIT
# FREE_SCAN_DAILY_LIMIT=5
# PLUS_SCAN_DAILY_LIMIT=20
# FREE_VOICE_DAILY_LIMIT=3
# PLUS_VOICE_DAILY_LIMIT=12
# FREE_ASSISTANT_DAILY_LIMIT=20
# PLUS_ASSISTANT_DAILY_LIMIT=80
# FREE_DREAM_VISUAL_DAILY_LIMIT=0
# PLUS_DREAM_VISUAL_DAILY_LIMIT=1
# FREE_DREAM_VISUAL_HQ_DAILY_LIMIT=0
# PLUS_DREAM_VISUAL_HQ_DAILY_LIMIT=1
# FREE_DREAM_STORY_DAILY_LIMIT=5
# PLUS_DREAM_STORY_DAILY_LIMIT=15
# FREE_DREAM_LOCALIZED_MEDIA_DAILY_LIMIT=5
# PLUS_DREAM_LOCALIZED_MEDIA_DAILY_LIMIT=15

# AI 加量包（Plus 专用；Checkout 外链 + webhook 入账）
# CREDIT_PACK_IMAGES_20_CHECKOUT_URL=https://...
# CREDIT_PACK_HQ_10_CHECKOUT_URL=https://...
# SUPABASE_SERVICE_ROLE_KEY=   # webhook 入账必需
# BILLING_WEBHOOK_SECRET=       # POST /api/billing/webhook Authorization: Bearer <secret>
